database -open waves -into waves.shm -default
probe -create -shm tb_multiplexed_bus_driver.uut.w_select tb_multiplexed_bus_driver.uut.i_data_a tb_multiplexed_bus_driver.uut.i_data_b tb_multiplexed_bus_driver.uut.i_en_a tb_multiplexed_bus_driver.uut.i_en_b tb_multiplexed_bus_driver.uut.o_bus_data tb_multiplexed_bus_driver.uut.w_mux_out
run
exit
